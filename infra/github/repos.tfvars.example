repositories = {
  "awesome-unraid" = {
    description = "Community Apps catalog for JSONbored Unraid AIO templates"
    topics = [
      "unraid",
      "community-applications",
      "docker",
      "self-hosted",
    ]
    required_checks = [
      "validate-catalog",
      "CodeQL",
      "Analyze (actions)",
    ]
  }

