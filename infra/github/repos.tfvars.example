      "postgresql",
      "redis",
      "ruby-on-rails",
      "s6-overlay",
      "self-hosted",
      "sure-finance",
      "unraid",
      "unraid-docker-template",
      "unraid-templates",
      "sure-aio",
    ]
    required_checks = [
      "aio-fleet / required",
    ]
    required_check_app_id = 3565017
  }

