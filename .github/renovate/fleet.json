{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Central low-noise dependency policy for the public JSONbored AIO fleet.",
  "platform": "github",
  "endpoint": "https://api.github.com/",
  "repositories": [
    "JSONbored/aio-fleet",
    "JSONbored/awesome-unraid",
    "JSONbored/dify-aio",
    "JSONbored/infisical-aio",
    "JSONbored/khoj-aio",
    "JSONbored/mem0-aio",
    "JSONbored/nanoclaw-aio",
    "JSONbored/penpot-aio",
    "JSONbored/signoz-aio",
    "JSONbored/simplelogin-aio",
    "JSONbored/sure-aio",
    "JSONbored/unraid-aio-template"
  ],
  "extends": ["config:recommended"],
  "onboarding": false,
  "requireConfig": "optional",
  "branchPrefix": "renovate/fleet/",
  "onboardingBranch": "renovate/fleet/configure",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "dependencyDashboard": true,
  "dependencyDashboardAutoclose": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "timezone": "America/Phoenix",
  "schedule": ["* 2-6 * * 1"],
  "updateNotScheduled": false,
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 2,
  "branchConcurrentLimit": 2,
  "prHourlyLimit": 1,
  "commitHourlyLimit": 2,
  "rebaseWhen": "conflicted",
  "enabledManagers": [
    "github-actions",
    "pep621",
    "pip_requirements",
    "pip_setup",
    "npm"
  ],
  "ignorePaths": [
    "**/.trunk/**",
    "**/rootfs/**",
    "**/rootfs-alpha/**",
    "**/patches/**"
  ],
  "packageRules": [
    {
      "description": "Group GitHub Actions updates so workflow pin churn stays reviewable.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Group Python test/control-plane dependencies by repo.",
      "matchManagers": ["pep621", "pip_requirements", "pip_setup"],
      "groupName": "python dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Group JavaScript dependencies where app repos carry package manifests.",
      "matchManagers": ["npm"],
      "groupName": "javascript dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Keep major upgrades separate and operator-approved.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "groupName": null
    }
  ]
}
